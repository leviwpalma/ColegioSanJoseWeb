@model ColegioSanJoseWeb.Models.Alumno

@{
    ViewData["Title"] = "Eliminar Alumno";
}

<style>
    /* Tarjeta de confirmación */
    .delete-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        border: 2px solid #dc3545;
        margin-top: 30px;
    }

    .warning-icon {
        font-size: 4rem;
        color: #dc3545;
        margin-bottom: 15px;
        display: block;
    }

    /* Caja de resumen del alumno */
    .student-info-box {
        background-color: #fff5f5;
        border-radius: 15px;
        padding: 25px;
        margin: 25px 0;
        border-left: 5px solid #dc3545;
    }

    .label-muted {
        color: #6c757d;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    /* Botones */
    .btn-custom {
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-danger-confirm {
        background: #dc3545;
        border: none;
        color: white;
    }

        .btn-danger-confirm:hover {
            background: #a71d2a;
            transform: scale(1.05);
            color: white;
        }

    .btn-secondary-outline {
        color: #6c757d;
        border: 1px solid #dee2e6;
    }

        .btn-secondary-outline:hover {
            background-color: #f8f9fa;
        }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="delete-card text-center">
                <span class="warning-icon">⚠️</span>
                <h2 class="text-danger fw-bold">¿Eliminar registro de alumno?</h2>
                <p class="text-muted">Está a punto de borrar toda la información de este estudiante. Esta acción no se puede deshacer.</p>

                <div class="student-info-box text-start">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <p class="label-muted mb-0">Nombre Completo</p>
                            <h5 class="fw-bold">@Model.Nombre @Model.Apellido</h5>
                        </div>
                        <div class="col-md-6 mb-3">
                            <p class="label-muted mb-0">Grado Académico</p>
                            <h5>@Html.DisplayFor(model => model.Grado)</h5>
                        </div>
                        <div class="col-12">
                            <p class="label-muted mb-0">Fecha de Nacimiento</p>
                            <p class="mb-0">@Model.FechaNacimiento.ToString("dd MMMM, yyyy")</p>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete">
                    @* Importante: El AlumnoId oculto para que el servidor identifique el registro *@
                    <input type="hidden" asp-for="AlumnoId" />

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-secondary-outline btn-custom">
                            No, regresar al listado
                        </a>
                        <button type="submit" class="btn btn-danger-confirm btn-custom shadow">
                            Sí, eliminar permanentemente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
