@model ColegioSanJoseWeb.Models.Alumno

@{
    ViewData["Title"] = "Nuevo Alumno";
}

<style>
    /* Tarjeta del formulario con elevación */
    .form-card {
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        border: none;
        margin-top: 30px;
    }

    .form-header {
        border-bottom: 2px solid #f0f0f0;
        margin-bottom: 25px;
        padding-bottom: 15px;
    }

    /* Estilo para los campos de texto y fechas */
    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #dee2e6;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #28a745;
            box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.15);
        }

    /* Botones modernos */
    .btn-custom {
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-create {
        background: linear-gradient(90deg, #28a745, #218838);
        border: none;
        color: white;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
            color: white;
        }

    .btn-back {
        color: #6c757d;
        border: 1px solid #dee2e6;
    }

        .btn-back:hover {
            background-color: #f8f9fa;
        }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-card">
                <div class="form-header text-center">
                    <h2 class="text-success fw-bold">👨‍🎓 Registro de Alumno</h2>
                    <p class="text-muted">Ingrese la información personal del estudiante</p>
                </div>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div class="row">
                        <!-- Nombre -->
                        <div class="col-md-6 mb-4">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-end-0">👤</span>
                                <input asp-for="Nombre" class="form-control border-start-0" placeholder="Ej: Juan" />
                            </div>
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <!-- Apellido -->
                        <div class="col-md-6 mb-4">
                            <label asp-for="Apellido" class="form-label fw-bold">Apellido</label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-end-0">👤</span>
                                <input asp-for="Apellido" class="form-control border-start-0" placeholder="Ej: Pérez" />
                            </div>
                            <span asp-validation-for="Apellido" class="text-danger small"></span>
                        </div>

                        <!-- Fecha de Nacimiento -->
                        <div class="col-md-6 mb-4">
                            <label asp-for="FechaNacimiento" class="form-label fw-bold">Fecha de Nacimiento</label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-end-0">📅</span>
                                <input asp-for="FechaNacimiento" type="date" class="form-control border-start-0" />
                            </div>
                            <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                        </div>

                        <!-- Grado -->
                        <div class="col-md-6 mb-4">
                            <label asp-for="Grado" class="form-label fw-bold">Grado Académico</label>
                            <div class="input-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text bg-light border-end-0">🎓</span>
                                <input asp-for="Grado" class="form-control border-start-0" placeholder="Ej: 9no Grado" />
                            </div>
                            <span asp-validation-for="Grado" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-back btn-custom">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-create btn-custom shadow">
                            Guardar Estudiante
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}